<div class="rounded border-l-4 border-gray-300 bg-white p-3 shadow-sm">
  <div class="flex justify-between">
    <span class="font-medium text-gray-700">{{ .User }}</span>
    <span class="text-xs text-gray-500">{{ .Timestamp.Format "15:04:05" }}</span>
  </div>
  <p class="mt-1 text-sm text-gray-600">{{ .Text }}</p>
</div>