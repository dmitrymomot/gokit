<div class="rounded border-l-4 border-green-500 bg-white p-3 shadow-sm">
  <div class="flex justify-between">
    <p class="font-medium text-gray-800">{{ .User }}</p>
    <span class="text-xs text-gray-500">{{ .Time.Format "15:04:05" }}</span>
  </div>
  <p class="text-sm text-gray-700 mt-1">{{ .Message }}</p>
</div>